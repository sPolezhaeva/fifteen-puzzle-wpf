<UserControl x:Class="FifteenPuzzle.WPF.Views.GameBoard"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Height="450" Width="400">
    <Grid>
        <ItemsControl x:Name="TilesControl">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <UniformGrid />
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Button Click="Tile_Click" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" MinWidth="60" MinHeight="60" Padding="4">
                        <TextBlock Text="{Binding}" FontSize="28" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Button>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
        <!-- Victory message overlay -->
        <Border x:Name="WinOverlay" Background="#AA000000" Visibility="Collapsed">
            <TextBlock x:Name="WinText" Text="You win!" Foreground="White" FontSize="36" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </Border>
    </Grid>
</UserControl>