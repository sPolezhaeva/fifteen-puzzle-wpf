        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:FifteenPuzzle.WPF.Views"
        Title="Fifteen Puzzle" Height="700" Width="700" WindowStartupLocation="CenterScreen">
    <Grid>
        <local:GameBoard x:Name="GameBoardControl" />
        <Button Content="New Game" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="10" Click="OnNewGameClick"/>
    </Grid>
</Window>